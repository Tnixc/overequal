<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{28} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Discord4J / Reactor Netty are very chatty at INFO; keep them at WARN. -->
    <logger name="discord4j" level="INFO"/>
    <logger name="reactor" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
